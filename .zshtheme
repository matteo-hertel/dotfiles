source /opt/homebrew/opt/powerlevel10k/share/powerlevel10k/powerlevel10k.zsh-theme
TERM="screen-256color"
POWERLEVEL9K_PROMPT_ON_NEWLINE=true
POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(custom_user dir vcs)
POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(status root_indicator background_jobs date time vi_mode)
POWERLEVEL9K_DATE_FORMAT=%D{%d/%m/%y}

POWERLEVEL9K_MODE='nerdfont-complete'

emoji() {
    echo -n "🐉 "
}
POWERLEVEL9K_CUSTOM_USER="emoji"
POWERLEVEL9K_CUSTOM_USER_BACKGROUND="blue"

# Prompt settings
POWERLEVEL9K_PROMPT_ON_NEWLINE=true


# --- colorsync theme start --- theme: tokyo-night
POWERLEVEL9K_CUSTOM_USER_BACKGROUND='#7aa2f7'
POWERLEVEL9K_CUSTOM_USER_FOREGROUND='#1a1b26'
POWERLEVEL9K_DIR_BACKGROUND='#414868'
POWERLEVEL9K_DIR_FOREGROUND='#c0caf5'
POWERLEVEL9K_VCS_CLEAN_BACKGROUND='#9ece6a'
POWERLEVEL9K_VCS_CLEAN_FOREGROUND='#1a1b26'
POWERLEVEL9K_VCS_MODIFIED_BACKGROUND='#e0af68'
POWERLEVEL9K_VCS_MODIFIED_FOREGROUND='#1a1b26'
POWERLEVEL9K_VCS_UNTRACKED_BACKGROUND='#f7768e'
POWERLEVEL9K_VCS_UNTRACKED_FOREGROUND='#c0caf5'
POWERLEVEL9K_STATUS_OK_FOREGROUND='#9ece6a'
POWERLEVEL9K_DATE_BACKGROUND='#414868'
POWERLEVEL9K_DATE_FOREGROUND='#c0caf5'
POWERLEVEL9K_TIME_BACKGROUND='#414868'
POWERLEVEL9K_TIME_FOREGROUND='#c0caf5'
POWERLEVEL9K_VI_MODE_NORMAL_BACKGROUND='#7aa2f7'
POWERLEVEL9K_VI_MODE_NORMAL_FOREGROUND='#1a1b26'
POWERLEVEL9K_VI_MODE_INSERT_BACKGROUND='#9ece6a'
POWERLEVEL9K_VI_MODE_INSERT_FOREGROUND='#1a1b26'
POWERLEVEL9K_VI_MODE_VISUAL_BACKGROUND='#bb9af7'
POWERLEVEL9K_VI_MODE_VISUAL_FOREGROUND='#1a1b26'
# --- colorsync theme end ---
