source /opt/homebrew/opt/powerlevel10k/share/powerlevel10k/powerlevel10k.zsh-theme
TERM="screen-256color"
POWERLEVEL9K_PROMPT_ON_NEWLINE=true
POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(custom_user dir vcs)
POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(status root_indicator background_jobs date time vi_mode)
POWERLEVEL9K_DATE_FORMAT=%D{%d/%m/%y}

POWERLEVEL9K_MODE='nerdfont-complete'

emoji() {
    echo -n "🐉 "
}
POWERLEVEL9K_CUSTOM_USER="emoji"
POWERLEVEL9K_CUSTOM_USER_BACKGROUND="blue"

# Prompt settings
POWERLEVEL9K_PROMPT_ON_NEWLINE=true


# --- colorsync theme start ---
POWERLEVEL9K_CUSTOM_USER_BACKGROUND='#4a7fb5'
POWERLEVEL9K_CUSTOM_USER_FOREGROUND='#0a1020'
POWERLEVEL9K_DIR_BACKGROUND='#2a3a54'
POWERLEVEL9K_DIR_FOREGROUND='#d4e5f7'
POWERLEVEL9K_VCS_CLEAN_BACKGROUND='#5b9ea6'
POWERLEVEL9K_VCS_CLEAN_FOREGROUND='#0a1020'
POWERLEVEL9K_VCS_MODIFIED_BACKGROUND='#8a9bb2'
POWERLEVEL9K_VCS_MODIFIED_FOREGROUND='#0a1020'
POWERLEVEL9K_VCS_UNTRACKED_BACKGROUND='#8c4a5a'
POWERLEVEL9K_VCS_UNTRACKED_FOREGROUND='#d4e5f7'
POWERLEVEL9K_STATUS_OK_FOREGROUND='#5b9ea6'
POWERLEVEL9K_DATE_BACKGROUND='#2a3a54'
POWERLEVEL9K_DATE_FOREGROUND='#d4e5f7'
POWERLEVEL9K_TIME_BACKGROUND='#2a3a54'
POWERLEVEL9K_TIME_FOREGROUND='#d4e5f7'
POWERLEVEL9K_VI_MODE_NORMAL_BACKGROUND='#4a7fb5'
POWERLEVEL9K_VI_MODE_NORMAL_FOREGROUND='#0a1020'
POWERLEVEL9K_VI_MODE_INSERT_BACKGROUND='#5b9ea6'
POWERLEVEL9K_VI_MODE_INSERT_FOREGROUND='#0a1020'
POWERLEVEL9K_VI_MODE_VISUAL_BACKGROUND='#7a6b9e'
POWERLEVEL9K_VI_MODE_VISUAL_FOREGROUND='#0a1020'
# --- colorsync theme end ---
